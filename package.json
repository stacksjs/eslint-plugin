{
  "name": "@stacksjs/eslint-plugin",
  "type": "module",
  "version": "0.1.5",
  "description": "The Stacks ESLint plugin",
  "license": "MIT",
  "funding": "https://github.com/sponsors/chrisbbreuer",
  "homepage": "https://github.com/stacksjs/eslint-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/stacksjs/eslint-plugin"
  },
  "bugs": {
    "url": "https://github.com/unocss/unocss/issues"
  },
  "keywords": [
    "eslint-plugin",
    "eslint"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build": "unbuild",
    "typecheck": "tsc --noEmit",
    "lint": "bun run build && cd ./fixtures && bunx eslint ./src",
    "changelog": "bunx changelogen --output CHANGELOG.md",
    "prepublishOnly": "bun run build",
    "release": "bun run changelog && bunx bumpp package.json --all"
  },
  "dependencies": {
    "@stacksjs/eslint-config": "^3.15.1-beta.4",
    "@typescript-eslint/utils": "^8.25.0",
    "@unocss/config": "65.5.0",
    "@unocss/core": "65.5.0",
    "magic-string": "^0.30.17",
    "synckit": "^0.9.2",
    "unocss": "^65.5.0"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.4.1",
    "@eslint/markdown": "^6.2.2",
    "@stacksjs/path": "^0.69.5",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/bun": "^1.2.4",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitest/eslint-plugin": "^1.1.34",
    "bumpp": "^9.11.1",
    "changelogen": "^0.6.0",
    "eslint-config-flat-gitignore": "^1.0.1",
    "eslint-flat-config-utils": "^1.1.0",
    "eslint-merge-processors": "^1.0.0",
    "eslint-plugin-antfu": "^2.7.0",
    "eslint-plugin-command": "^2.1.0",
    "eslint-plugin-format": "^1.0.1",
    "eslint-plugin-import-x": "^4.6.1",
    "eslint-plugin-jsdoc": "^50.6.3",
    "eslint-plugin-jsonc": "^2.19.1",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^4.9.0",
    "eslint-plugin-regexp": "^2.7.0",
    "eslint-plugin-toml": "^0.12.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^9.32.0",
    "eslint-plugin-yml": "^1.17.0",
    "eslint-processor-vue-blocks": "^1.0.0",
    "eslint-vitest-rule-tester": "^1.1.0",
    "unbuild": "3.4.2",
    "vitest": "^3.0.7",
    "vue-eslint-parser": "^9.4.3"
  }
}
